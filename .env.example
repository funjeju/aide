# ===========================================
# Aide 환경변수 템플릿
# 실제 값은 .env.local 또는 .env 파일에 설정
# ===========================================

# ── Firebase (공통) ──────────────────────────
FIREBASE_PROJECT_ID=app-dev
FIREBASE_STORAGE_BUCKET=app-dev.appspot.com

# ── Firebase Admin SDK (functions 전용) ──────
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ── Gemini AI ────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Whisper (백업 STT) ───────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── RevenueCat ───────────────────────────────
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-secret

# ── Sentry ───────────────────────────────────
SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── Slack (알림) ─────────────────────────────
SLACK_WEBHOOK_URL=your-slack-webhook-url

# ===========================================
# 모바일 앱 (EXPO_PUBLIC_ prefix = 클라이언트 공개)
# ===========================================
EXPO_PUBLIC_ENV=development

EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=app-dev.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=app-dev
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=app-dev.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxx

EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn

# ===========================================
# 어드민 콘솔 (NEXT_PUBLIC_ prefix = 클라이언트 공개)
# ===========================================
NEXT_PUBLIC_ENV=development

NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=app-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=app-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=app-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# 어드민 서버 시크릿 (Secret Manager에서 로드)
ADMIN_JWT_SECRET=your-admin-jwt-secret
TOTP_ENCRYPTION_KEY=your-32-char-totp-encryption-key
